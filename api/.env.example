# ===========================================
# NotifyX API Configuration
# ===========================================

# Server
PORT=3000
NODE_ENV=production

# CORS (comma-separated origins, or * for all)
CORS_ORIGIN=https://yourdomain.com

# ===========================================
# Database (Required)
# ===========================================
DATABASE_URL="postgresql://admin:password@localhost:5432/notifyx?schema=public"

# Connection Pooling
DATABASE_POOL_SIZE=10
DATABASE_CONNECTION_TIMEOUT=10000

# ===========================================
# Redis (Required)
# ===========================================
REDIS_URL="redis://localhost:6379"

# ===========================================
# Security (Required for Production)
# ===========================================

# API Key Authentication (comma-separated for multiple keys)
API_KEYS="your-api-key-here,another-api-key"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# Worker Configuration
# ===========================================
NORMAL_WORKER_CONCURRENCY=5
NORMAL_WORKER_RATE_LIMIT=50
HIGH_WORKER_CONCURRENCY=20
HIGH_WORKER_RATE_LIMIT=500

# ===========================================
# Firebase Cloud Messaging (FCM)
# OPTIONAL: Global fallback when app has no credentials
# For production, configure per-app via API
# ===========================================
# FCM_PROJECT_ID="your-firebase-project-id"
# FCM_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
# FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ===========================================
# Huawei Mobile Services (HMS)
# OPTIONAL: Global fallback when app has no credentials
# ===========================================
# HMS_APP_ID="your-huawei-app-id"
# HMS_APP_SECRET="your-huawei-app-secret"

# ===========================================
# Apple Push Notification Service (APNS)
# OPTIONAL: Global fallback when app has no credentials
# ===========================================
# APNS_KEY_ID="YOUR_KEY_ID"
# APNS_TEAM_ID="YOUR_TEAM_ID"
# APNS_BUNDLE_ID="com.yourapp.bundle"
# APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_P8_KEY_HERE\n-----END PRIVATE KEY-----"
# APNS_PRODUCTION="false"

# ===========================================
# Web Push (VAPID)
# OPTIONAL: Global fallback for browser notifications
# Generate keys: npx web-push generate-vapid-keys
# ===========================================
# VAPID_PUBLIC_KEY="your-vapid-public-key"
# VAPID_PRIVATE_KEY="your-vapid-private-key"
# VAPID_SUBJECT="mailto:admin@yourdomain.com"

# ===========================================
# Object Storage (MinIO/S3)
# ===========================================
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="admin"
MINIO_SECRET_KEY="password"
MINIO_USE_SSL=false
MINIO_BUCKET="notifications"

# ===========================================
# Logging
# ===========================================
LOG_LEVEL="info"
LOG_FORMAT="json"

# ===========================================
# Dead Letter Queue
# ===========================================
DLQ_MAX_RETRIES=5
DLQ_ALERT_THRESHOLD=100
