# Portal Environment Configuration
# Copy to .env and customize

# API URL (without trailing slash)
# For same-host Dokploy routing, use the site root, not /api.
VITE_API_URL=http://localhost:3000
# Dokploy example:
# VITE_API_URL=https://notification.sadeek.app

# API Key for authentication (optional in development)
VITE_API_KEY=your-api-key-here
